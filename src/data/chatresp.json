  "responseRules": [
    {
      "id": "standup-all",
      "priority": 100,
      "match": {
        "mode": "all",
        "terms": ["standup", "blocker"]
      },
      "response": {
        "author": "Mia",
        "parts": [
          { "type": "text", "text": "Noted for standup and blocker review. I pinned this for the morning sync." }
        ]
      }
    },
    {
      "id": "dashboard-any",
      "priority": 80,
      "match": {
        "mode": "any",
        "terms": ["status", "dashboard", "metric"]
      },
      "response": {
        "author": "Leo",
        "parts": [
          { "type": "text", "text": "Updated metrics are ready:" },
          {
            "type": "table",
            "columns": ["Metric", "Value"],
            "rows": [
              ["Cycle time", "2.1d"],
              ["Deployment freq", "5/day"]
            ]
          }
        ]
      }
    },
    {
      "id": "release-regex",
      "priority": 60,
      "match": {
        "mode": "regex",
        "pattern": "release\\s*v?\\d+",
        "flags": "i"
      },
      "response": {
        "author": "Mia",
        "parts": [
          { "type": "text", "text": "Release callout detected. I will add this to the release checklist." }
        ]
      }
    },
    {
      "id": "design-hero-any",
      "priority": 70,
      "match": {
        "mode": "any",
        "terms": ["mockup", "hero", "image"]
      },
      "response": {
        "author": "Ava",
        "parts": [
          { "type": "text", "text": "Here is the latest visual option." },
          {
            "type": "image",
            "src": "/favicon.svg",
            "alt": "Design preview",
            "caption": "Preview from design bot"
          }
        ]
      }
    },
    {
      "id": "design-color-exact",
      "priority": 50,
      "match": {
        "mode": "exact",
        "terms": ["color review"]
      },
      "response": {
        "author": "Ava",
        "parts": [
          { "type": "text", "text": "Color review request accepted. I will post contrast notes in 30 minutes." }
        ]
      }
    },
    {
      "id": "engineering-latency-any",
      "priority": 90,
      "match": {
        "mode": "any",
        "terms": ["error", "latency", "api"]
      },
      "response": {
        "author": "Noah",
        "parts": [
          { "type": "text", "text": "Current service telemetry:" },
          {
            "type": "chart",
            "title": "API latency (ms)",
            "series": [
              { "label": "p50", "value": 95, "color": "#22d3ee" },
              { "label": "p90", "value": 210, "color": "#06b6d4" },
              { "label": "p99", "value": 420, "color": "#0284c7" }
            ]
          }
        ]
      }
    },
    {
      "id": "engineering-deploy-starts",
      "priority": 40,
      "match": {
        "mode": "startsWith",
        "terms": ["deploy", "deployment"]
      },
      "response": {
        "author": "Noah",
        "parts": [
          { "type": "text", "text": "Deployment update received. I will share rollout status shortly." }
        ]
      }
    }
  ],
  "issueBot": {
    "author": "Justin",
    "ticketPrefix": "TCK",
    "ticketChannelPrefix": "ticket",
    "intakeIntro": "I cannot solve this immediately. I need a few details before I create a support ticket.",
    "questions": [
      {
        "key": "impact",
        "label": "Impact",
        "question": "Who is impacted and how severe is it?"
      },
      {
        "key": "environment",
        "label": "Environment",
        "question": "Which environment is affected (prod/staging/dev)?"
      },
      {
        "key": "frequency",
        "label": "Frequency",
        "question": "How often does it happen and since when?"
      },
      {
        "key": "attemptedFix",
        "label": "Attempted Fix",
        "question": "What have you already tried?"
      }
    ]
  }
}
